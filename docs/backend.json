
{
  "entities": {
    "Factory": {
      "title": "Factory",
      "type": "object",
      "description": "Manufacturing factory information.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name"]
    },
    "CatalogProduct": {
      "title": "CatalogProduct",
      "type": "object",
      "description": "Product pricing extracted from XLSX.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "unit": { "type": "string" },
        "closedLoadPrice": { "type": "number" },
        "fractionalLoadPrice": { "type": "number" },
        "discountAmount": { "type": "number", "description": "Discount in R$ extracted from sheet" },
        "factoryId": { "type": "string" },
        "lastPriceUpdateAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "unit", "closedLoadPrice", "factoryId"]
    },
    "RegisteredProduct": {
      "title": "RegisteredProduct",
      "type": "object",
      "description": "Master parallel product registration for sellers.",
      "properties": {
        "id": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "brand": { "type": "string" },
        "line": { "type": "string" },
        "code": { "type": "string" },
        "description": { "type": "string" },
        "quantityPerBox": { "type": "number" },
        "unit": { "type": "string" },
        "ean": { "type": "string" },
        "dun14": { "type": "string" },
        "taxClassification": { "type": "string" },
        "ncm": { "type": "string" },
        "cest": { "type": "string" },
        "unitNetWeightKg": { "type": "number" },
        "boxWeightKg": { "type": "number" },
        "st": { "type": "string" },
        "factoryId": { "type": "string" },
        "catalogProductId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "status", "code", "description"]
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "description": "Customer order history.",
      "properties": {
        "id": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "totalWeight": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/factories/{factoryId}": {
      "schema": "#/entities/Factory",
      "description": "Factories list."
    },
    "/catalog_products/{catalogProductId}": {
      "schema": "#/entities/CatalogProduct",
      "description": "Master pricing catalog."
    },
    "/registered_products/{registeredProductId}": {
      "schema": "#/entities/RegisteredProduct",
      "description": "Parallel product registrations."
    },
    "/orders/{orderId}": {
      "schema": "#/entities/Order",
      "description": "Orders history."
    }
  }
}
