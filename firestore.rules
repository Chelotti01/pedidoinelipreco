rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- COLLECTION RULES ---

    /**
     * @description Perfis de usuário para controle de organização (SaaS).
     */
    match /userProfiles/{email} {
      allow get: if isSignedIn() && (request.auth.token.email.lower() == email.lower() || isAdmin());
      allow list, create, update, delete: if isAdmin() || (isSignedIn() && request.auth.token.email == 'vendas.piracanjuba@gmail.com');
    }

    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if false;
    }

    /**
     * @description Estrutura de Organizações e subcoleções.
     */
    match /organizations/{orgId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.auth.token.email == 'vendas.piracanjuba@gmail.com');

      // Clientes da organização
      match /clients/{clientId} {
        allow read, write: if isSignedIn();
      }

      // Fábricas da organização
      match /factories/{factoryId} {
        allow read, write: if isSignedIn();
      }

      // Produtos registrados (Ficha técnica)
      match /products/{productId} {
        allow read, write: if isSignedIn();
      }

      // Preços de catálogo importados
      match /productFactoryPrices/{priceId} {
        allow read, write: if isSignedIn();
      }

      // Pedidos
      match /orders/{orderId} {
        allow read, write: if isSignedIn();
      }

      // Configuração de Grupos de PDF
      match /pdfGroups/{groupId} {
        allow read, write: if isSignedIn();
      }
    }

    // Regras legadas para compatibilidade
    match /factories/{factoryId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /products/{productId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}