rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MULTI-TENANT SAAS SECURITY MODEL
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid)) ||
        request.auth.token.email == 'vendas.piracanjuba@gmail.com'
      );
    }

    function getUserData() {
      // Busca perfil pelo e-mail (ID do documento)
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.token.email)).data;
    }

    function hasOrgAccess(orgId) {
      return isSignedIn() && (isSuperAdmin() || getUserData().organizationId == orgId);
    }

    function isOrgAdmin(orgId) {
      return isSignedIn() && (isSuperAdmin() || (getUserData().organizationId == orgId && getUserData().role == 'admin'));
    }

    // --- COLLECTION RULES ---

    match /superAdmins/{userId} {
      allow get: if isSignedIn();
      allow list: if isSuperAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    match /userProfiles/{profileId} {
      // Permite get público para verificar convite durante ativação de conta
      allow get: if true;
      allow list: if isSuperAdmin() || (isSignedIn() && (profileId == request.auth.token.email));
      allow create: if isSuperAdmin() || (isSignedIn() && !exists(/databases/$(database)/documents/userProfiles/$(request.auth.token.email)));
      allow update: if isSuperAdmin() || (isSignedIn() && profileId == request.auth.token.email);
      allow delete: if isSuperAdmin();
    }

    match /organizations/{organizationId} {
      allow get: if hasOrgAccess(organizationId);
      allow list: if isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update: if isOrgAdmin(organizationId);
      allow delete: if isSuperAdmin();
    }

    match /organizations/{organizationId}/factories/{factoryId} {
      allow get, list: if hasOrgAccess(organizationId);
      allow create: if isOrgAdmin(organizationId);
      allow update, delete: if isOrgAdmin(organizationId);
    }

    match /organizations/{organizationId}/products/{productId} {
      allow get, list: if hasOrgAccess(organizationId);
      allow create: if isOrgAdmin(organizationId);
      allow update, delete: if isOrgAdmin(organizationId);
    }

    match /organizations/{organizationId}/productFactoryPrices/{priceId} {
      allow get, list: if hasOrgAccess(organizationId);
      allow create: if isOrgAdmin(organizationId);
      allow update, delete: if isOrgAdmin(organizationId);
    }

    match /organizations/{organizationId}/discounts/{discountId} {
      allow get, list: if hasOrgAccess(organizationId);
      allow create: if isOrgAdmin(organizationId);
      allow update, delete: if isOrgAdmin(organizationId);
    }

    match /organizations/{organizationId}/clients/{clientId} {
      allow get, list: if hasOrgAccess(organizationId);
      allow create: if hasOrgAccess(organizationId);
      allow update: if isOrgAdmin(organizationId) || hasOrgAccess(organizationId);
      allow delete: if isOrgAdmin(organizationId);
    }

    match /organizations/{organizationId}/orders/{orderId} {
      allow get, list: if hasOrgAccess(organizationId);
      allow create: if hasOrgAccess(organizationId);
      allow update: if hasOrgAccess(organizationId);
      allow delete: if isOrgAdmin(organizationId);

      match /orderItems/{orderItemId} {
        allow get, list: if hasOrgAccess(organizationId);
        allow create, update, delete: if hasOrgAccess(organizationId);
      }
    }
  }
}