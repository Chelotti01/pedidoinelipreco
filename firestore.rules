
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PEDIDO INTELIPREÇO: REGRAS LIBERADAS PARA DESENVOLVIMENTO
     * ATENÇÃO: Acesso público total habilitado conforme solicitado.
     */

    match /{document=**} {
      allow read, write: if true;
    }
  }
}
