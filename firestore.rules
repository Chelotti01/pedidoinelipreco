
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PEDIDO INTELIPREÇO: PROTOTYPE SECURITY RULES
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    match /factories/{factoryId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /catalog_products/{catalogProductId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /discounts/{discountId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /registered_products/{registeredProductId} {
      allow get, list, create, update, delete: if isSignedIn();
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if isAdmin();
    }

    match /roles_seller/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }
  }
}
