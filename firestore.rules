rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica se é o administrador mestre ou possui documento em roles_admin
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        request.auth.token.email == 'vendas.piracanjuba@gmail.com'
      );
    }

    // --- COLLECTION RULES ---

    /**
     * @description Perfis de usuário para controle de organização (SaaS).
     */
    match /userProfiles/{email} {
      allow read: if isSignedIn() && (request.auth.token.email.lower() == email.lower() || isAdmin());
      allow write: if isAdmin();
    }

    match /roles_admin/{adminId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    /**
     * @description Estrutura de Organizações e subcoleções.
     * Usamos match recursivo para garantir que o administrador mestre e usuários 
     * autenticados possam acessar os dados necessários.
     */
    match /organizations/{orgId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();

      // Regra para todas as subcoleções (clientes, fábricas, produtos, pedidos, etc.)
      match /{allSubcollections=**} {
        allow read: if isSignedIn();
        allow write: if isAdmin() || isSignedIn(); 
      }
    }

    // Regras de compatibilidade para coleções legadas no nível raiz
    match /factories/{factoryId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /discounts/{discountId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /productGroups/{groupId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}