
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Funções Auxiliares ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Rodrigo (Admin) e Demo - Acesso Total
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'vendas.piracanjuba@gmail.com' || 
        request.auth.token.email == 'rodrigo@inteli-preco.com' ||
        request.auth.token.email == 'demo@inteli-preco.com'
      );
    }

    // --- Regras por Coleção ---

    match /userProfiles/{userId} {
      allow get: if isSignedIn();
      allow create, update: if isAdmin();
    }

    match /factories/{factoryId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /catalog_products/{productId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /registered_products/{productId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /customers/{customerId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /discounts/{discountId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      // Adriana, Rodrigo e Demo podem criar pedidos
      allow create: if isSignedIn();
      
      // Rodrigo e Demo veem tudo. Adriana vê apenas os dela.
      allow get, list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      // Apenas Rodrigo e Demo podem editar ou excluir
      allow update, delete: if isAdmin();

      match /orderItems/{orderItemId} {
        allow read, write: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/orders/$(orderId)).data.userId == request.auth.uid);
      }
    }
  }
}
